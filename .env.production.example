# Production environment variables. Do not commit real secrets.

# Use Razorpay Live Mode keys for real payments.
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret

# Hosting platforms usually set PORT automatically.
# SPEED_ACCOUNTING_HOST can stay 0.0.0.0 online.
SPEED_ACCOUNTING_HOST=0.0.0.0

# Optional: set this to a persistent disk path on your hosting provider.
DATABASE_PATH=backend/speed_accounting.db

# Optional email settings.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASSWORD=
