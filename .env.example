# Speed Accounting Backend - Configuration
# Copy this file to .env and fill in your actual credentials

# ===== RAZORPAY PAYMENT GATEWAY =====
# Get these from: https://dashboard.razorpay.com
# Use TEST keys for development (rzp_test_...)
RAZORPAY_KEY_ID=rzp_test_1234567890
RAZORPAY_KEY_SECRET=test_secret_key_here

# ===== EMAIL CONFIGURATION =====
# Setup Gmail App Password: https://myaccount.google.com/apppasswords
# Enable 2FA first on your Google account

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# ===== SERVER CONFIGURATION =====
SPEED_ACCOUNTING_HOST=127.0.0.1
SPEED_ACCOUNTING_PORT=8765

# ===== DATABASE =====
# SQLite database path (auto-created)
# DATABASE_PATH=./backend/speed_accounting.db
